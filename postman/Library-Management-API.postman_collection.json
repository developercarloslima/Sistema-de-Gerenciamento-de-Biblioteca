{
  "info": {
    "name": "Library Management API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "memberId",
      "value": ""
    },
    {
      "key": "bookId",
      "value": ""
    },
    {
      "key": "copyId",
      "value": ""
    },
    {
      "key": "loanId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Login ADMIN",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@library.local\",\n  \"password\": \"Admin@123456\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.collectionVariables.set('token', pm.response.json().accessToken);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Meu perfil",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/me",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "me"
          ]
        }
      }
    },
    {
      "name": "Criar membro",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/members",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "members"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Maria da Silva\",\n  \"email\": \"maria@example.com\",\n  \"password\": \"Senha@123\",\n  \"phone\": \"82999999999\",\n  \"maximumLoans\": 3\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.collectionVariables.set('memberId', pm.response.json().id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Criar livro",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/books",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "books"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Clean Code\",\n  \"isbn\": \"9780132350884\",\n  \"author\": \"Robert C. Martin\",\n  \"publisher\": \"Prentice Hall\",\n  \"publicationYear\": 2008,\n  \"category\": \"Tecnologia\",\n  \"description\": \"Boas práticas de desenvolvimento de software.\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.collectionVariables.set('bookId', pm.response.json().id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Criar exemplar",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/books/{{bookId}}/copies",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "books",
            "{{bookId}}",
            "copies"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"inventoryCode\": \"INV-0001\",\n  \"acquisitionDate\": \"2026-07-15\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.collectionVariables.set('copyId', pm.response.json().id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Listar livros",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/books?availableOnly=true",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "books?availableOnly=true"
          ]
        }
      }
    },
    {
      "name": "Criar empréstimo",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/loans",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "loans"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"memberId\": \"{{memberId}}\",\n  \"bookCopyId\": \"{{copyId}}\",\n  \"loanDays\": 14\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.collectionVariables.set('loanId', pm.response.json().id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Renovar empréstimo",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/loans/{{loanId}}/renew",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "loans",
            "{{loanId}}",
            "renew"
          ]
        }
      }
    },
    {
      "name": "Devolver empréstimo",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/loans/{{loanId}}/return",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "loans",
            "{{loanId}}",
            "return"
          ]
        }
      }
    },
    {
      "name": "Listar multas",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/fines",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "fines"
          ]
        }
      }
    },
    {
      "name": "Criar funcionário",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/staff",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "staff"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Bibliotecário\",\n  \"email\": \"bibliotecario@library.local\",\n  \"password\": \"Senha@123\",\n  \"role\": \"LIBRARIAN\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      }
    }
  ]
}